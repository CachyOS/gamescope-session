#!/bin/bash
set -e

# Session, gamescope or gnome
SESSION="${1:-gamescope}"

die() { echo >&2 "!! $*"; exit 1; }

case "$SESSION" in
    'gamescope')
        pkexec /usr/lib/steamos/steam-set-session gamescope-session
        dbus-send --session --type=method_call --print-reply --dest=org.gnome.SessionManager /org/gnome/SessionManager org.gnome.SessionManager.Logout uint32:1;;
    'plasma')
        pkexec /usr/lib/steamos/steam-set-session gnome
        steam -shutdown
        systemctl --user stop gamescope-session.target
        sleep 10
        # User must be terminated or otherwise GDM would not allow you to relogin
        sudo loginctl terminate-user 1000;;
    *)
        die "Unknown session '$SESSION'";;
esac

if [[ -e /dev/input/.hidden ]]; then
    echo "Unhide hidden controller devices as needed"
    pkexec mv /dev/input/.hidden/* /dev/input
    pkexec rm -r /dev/input/.hidden
fi
